rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user', 'developer', 'admin')
    //   - bio: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - id: string (required, immutable)
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - developerId: string (required, immutable)
    //   - category: string (required, 'aimbot', 'triggerbot', 'spoofer')
    //   - game: string (required)
    //   - features: list of strings (optional)
    //   - imageUrl: string (optional)
    //   - status: string (required, 'active', 'inactive')
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - id: string (required, immutable)
    //   - productId: string (required, immutable)
    //   - userId: string (required, immutable)
    //   - rating: number (required, 1-5)
    //   - comment: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: purchases
    // Document ID: {purchaseId}
    // Fields:
    //   - id: string (required, immutable)
    //   - userId: string (required, immutable)
    //   - productId: string (required, immutable)
    //   - licenseKey: string (required)
    //   - downloadUrl: string (required)
    //   - purchasedAt: timestamp (required, immutable)
    //   - status: string (required, 'active', 'expired', 'revoked')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "xanderberanek2013@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDeveloper() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer';
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'role', 'bio', 'createdAt']) &&
             hasRequiredFields(['uid', 'displayName', 'role', 'createdAt']) &&
             validStringLength('uid', 1, 100) &&
             validStringLength('displayName', 1, 100) &&
             isValidOptionalString('photoURL', 0, 1000) &&
             isValidOptionalString('bio', 0, 1000) &&
             data.role in ['user', 'developer', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'name', 'description', 'price', 'developerId', 'category', 'game', 'features', 'imageUrl', 'status', 'createdAt']) &&
             hasRequiredFields(['id', 'name', 'description', 'price', 'developerId', 'category', 'game', 'status', 'createdAt']) &&
             validStringLength('id', 1, 100) &&
             validStringLength('name', 1, 100) &&
             validStringLength('description', 1, 5000) &&
             data.price is number && data.price >= 0 &&
             validStringLength('developerId', 1, 100) &&
             data.category in ['aimbot', 'triggerbot', 'spoofer'] &&
             validStringLength('game', 1, 100) &&
             (!( 'features' in data ) || data.features is list) &&
             isValidOptionalString('imageUrl', 0, 1000) &&
             data.status in ['active', 'inactive'] &&
             data.createdAt is timestamp;
    }

    function isValidReview() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'productId', 'userId', 'rating', 'comment', 'createdAt']) &&
             hasRequiredFields(['id', 'productId', 'userId', 'rating', 'comment', 'createdAt']) &&
             validStringLength('id', 1, 100) &&
             validStringLength('productId', 1, 100) &&
             validStringLength('userId', 1, 100) &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             validStringLength('comment', 1, 2000) &&
             data.createdAt is timestamp;
    }

    function isValidPurchase() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'userId', 'productId', 'licenseKey', 'downloadUrl', 'purchasedAt', 'status']) &&
             hasRequiredFields(['id', 'userId', 'productId', 'licenseKey', 'downloadUrl', 'purchasedAt', 'status']) &&
             validStringLength('id', 1, 100) &&
             validStringLength('userId', 1, 100) &&
             validStringLength('productId', 1, 100) &&
             validStringLength('licenseKey', 1, 100) &&
             validStringLength('downloadUrl', 1, 1000) &&
             data.status in ['active', 'expired', 'revoked'] &&
             data.purchasedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isAuthenticated() && isValidUser() && uidUnchanged() && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && uidNotModified() && 
                    areImmutableFieldsUnchanged(['uid', 'createdAt']) &&
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Public products
      allow create: if isAuthenticated() && isValidProduct() && 
                    (request.resource.data.developerId == request.auth.uid) && 
                    (isDeveloper() || isAdmin());
      allow update: if isAuthenticated() && isValidProduct() && 
                    areImmutableFieldsUnchanged(['id', 'developerId', 'createdAt']) &&
                    ((resource.data.developerId == request.auth.uid && isDeveloper()) || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.developerId == request.auth.uid && isDeveloper());
    }

    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isAuthenticated() && isValidReview() && 
                    (request.resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && isValidReview() && 
                    areImmutableFieldsUnchanged(['id', 'productId', 'userId', 'createdAt']) &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPurchase() && 
                    (request.resource.data.userId == request.auth.uid); // In a real app, this would be restricted to backend
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
