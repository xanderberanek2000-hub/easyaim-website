{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system, including developers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "developer", "admin"], "description": "The user's role." },
        "bio": { "type": "string", "description": "A short biography for developers." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "displayName", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A software product listed in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The product's unique ID." },
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description." },
        "price": { "type": "number", "description": "The price of the product." },
        "developerId": { "type": "string", "description": "The UID of the developer who created this product." },
        "category": { "type": "string", "enum": ["aimbot", "triggerbot", "spoofer"], "description": "The category of the product." },
        "game": { "type": "string", "description": "The game this product is for." },
        "features": { "type": "array", "items": { "type": "string" }, "description": "List of features." },
        "imageUrl": { "type": "string", "description": "URL to the product image." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Whether the product is currently available." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was listed." }
      },
      "required": ["id", "name", "description", "price", "developerId", "category", "game", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The review's unique ID." },
        "productId": { "type": "string", "description": "The ID of the product being reviewed." },
        "userId": { "type": "string", "description": "The UID of the user who wrote the review." },
        "rating": { "type": "number", "description": "Rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was posted." }
      },
      "required": ["id", "productId", "userId", "rating", "comment", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A record of a user purchasing a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The purchase's unique ID." },
        "userId": { "type": "string", "description": "The UID of the user who made the purchase." },
        "productId": { "type": "string", "description": "The ID of the purchased product." },
        "licenseKey": { "type": "string", "description": "The generated license key." },
        "downloadUrl": { "type": "string", "description": "The URL to download the software." },
        "purchasedAt": { "type": "string", "format": "date-time", "description": "When the purchase was made." },
        "status": { "type": "string", "enum": ["active", "expired", "revoked"], "description": "The status of the license." }
      },
      "required": ["id", "userId", "productId", "licenseKey", "downloadUrl", "purchasedAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores marketplace products."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores product reviews."
    },
    "/purchases/{purchaseId}": {
      "schema": { "$ref": "#/entities/Purchase" },
      "description": "Stores user purchases and licenses."
    }
  }
}
